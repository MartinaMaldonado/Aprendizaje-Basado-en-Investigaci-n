}

@CONFERENCE{Segato20202429,
	author = {Segato, Alice and Sestini, Luca and Castellano, Antonella and De Momi, Elena},
	title = {GA3C Reinforcement Learning for Surgical Steerable Catheter Path Planning},
	year = {2020},
	journal = {Proceedings - IEEE International Conference on Robotics and Automation},
	pages = {2429 - 2435},
	doi = {10.1109/ICRA40945.2020.9196954},
	url = {https://www.scopus.com/pages/publications/85092694125?origin=resultslist},
	abstract = {Path planning algorithms for steerable catheters, must guarantee anatomical obstacles avoidance, reduce the insertion length and ensure the compliance with needle kinematics. The majority of the solutions in literature focuses on graph based or sampling based methods, both limited by the impossibility to directly obtain smooth trajectories. In this work we formulate the path planning problem as a reinforcement learning problem and show that the trajectory planning model, generated from the training, can provide the user with optimal trajectories in terms of obstacle clearance and kinematic constraints. We obtain 2D and 3D environments from MRI images processing and we implement a GA3C algorithm to create a path planning model, able to generalize on different patients anatomies. The curvilinear trajectories obtained from the model in 2D and 3D environments are compared to the ones obtained by A∗ and RRT∗ algorithms. Our method achieves state-of-the-art performances in terms of obstacle avoidance, trajectory smoothness and computational time proving this algorithm as valid planning method for complex environments. © 2020 IEEE.},
	type = {Conference paper},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 27; All Open Access; Green Open Access}
}

@ARTICLE{Hu202592519,
	author = {Hu, Yibo and Wei, Lai and Guo, Xiaoyu and Li, Zhenyao and Wei, Yanding and Fang, Qiang},
	title = {Priority-Based Reward Mechanism for Dual-Robot Path Planning in Dynamic Environments},
	year = {2025},
	journal = {IEEE Access},
	volume = {13},
	pages = {92519 - 92530},
	doi = {10.1109/ACCESS.2025.3571931},
	url = {https://www.scopus.com/pages/publications/105005572589?origin=resultslist},
	abstract = {The definition of motion priority enables robot groups to handle competition and cooperation better when performing physical tasks. In this paper, we propose a priority-based step reward mechanism, which is a new reward mechanism for deep reinforcement learning of multi-robot systems and can improve collaboration between robotic arms in shared workspaces. The intention of each agent is provided to other agents, presenting a 2D map of the head that is visually consistent, with state and action representations aligned spatially. Guided by priority-based step rewards, the dual-robots are sequentially assigned high priority, enabling them to pass through complex environments in sequence. We validated our method on a path planning task where two robots collaborate to transport cubes in dynamic environments. The two robots need to consider obstacle avoidance while handing cubes to the human operator. The experimental environment includes Free space, obstacles in the middle, obstacles on both sides, and combinations of several environments. The results show that priority step rewards improve the performance of robot collaborative tasks and significantly enhance cooperative behavior. © 2025 The Authors.},
	type = {Article},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 0; All Open Access; Gold Open Access; Green Open Access}
}

@CONFERENCE{Crafts2021,
	author = {Crafts, David and Sousa, Jake and McLellan, William and Robson, Nathan and Pham, Cuong},
	title = {An Efficient and Reliable Multi-Robot Navigation Platform with Collision Avoidance},
	year = {2021},
	journal = {2021 IEEE MIT Undergraduate Research Technology Conference, URTC 2021},
	pages = {},
	doi = {10.1109/URTC54388.2021.9701650},
	url = {https://www.scopus.com/pages/publications/85127443988?origin=resultslist},
	abstract = {With the ever-increasing demand for consumer goods, companies are pivoting towards semi or fully autonomous robotic warehouses to efficiently fulfill orders. Large companies have become increasingly reliant on autonomous robotic warehouse solutions, however, the demand from small to medium-sized companies has increased dramatically [8]. These companies often rely on manual solutions, such as forklifts, to traverse their warehouses. In 2019, forklifts accounted for 79 work related deaths and 8,140 nonfatal injuries [9]. Warehouse accidents are the direct result of their fast paced, ever-changing nature. With warehouses containing a multitude of static and dynamic variables, an open-source robotics platform is needed that can safely traverse a warehouse, preventing unnecessary death and injury. The proposed solution allows for the safe and effective navigation of these environments utilizing a path-planning algorithm in tandem with a dynamic obstacle avoidance algorithm. The dynamic obstacle avoidance algorithm uses LiDAR sensor data to detect and avoid obstacles along a path. The path-planning algorithm uses a map of a warehouse environment that accounts for static objects, such as shelves, and generates an efficient path from a starting point to a goal point. These algorithms are simulated in Gazebo allowing for a detailed visual of the platform's performance. These algorithms, together, create a platform that allows for robots to autonomously navigate to desired destinations while safely avoiding a myriad of obstacles.  © 2021 IEEE.},
	type = {Conference paper},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 0}
}

@CONFERENCE{Brahmi2013199,
