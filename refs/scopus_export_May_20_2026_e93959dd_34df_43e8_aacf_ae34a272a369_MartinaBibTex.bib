	url = {https://www.scopus.com/pages/publications/105035483463?origin=resultslist},
	abstract = {The A∗ algorithm is a classical and widely adopted method for path planning due to its completeness and optimality. However, its performance in complex, obstacle-rich environments is often constrained by static heuristic functions, high memory consumption, and reduced computational efficiency, especially when applied to large-scale maps or real-time navigation tasks. In this study, we propose an enhanced A∗ algorithm that addresses these limitations through two key innovations: a dynamic heuristic adjustment mechanism and a memory-efficient node management strategy. The dynamic heuristic component allows the algorithm to adapt its search behavior based on local map features and obstacle distributions, improving responsiveness and reducing unnecessary expansions. Meanwhile, the optimized memory structure minimizes redundant storage and accelerates node retrieval, significantly lowering the overall resource footprint. To validate the effectiveness of the proposed method, we conducted extensive experiments across multiple obstacle-dense map scenarios with varying complexity levels. Comparative results demonstrate that our approach achieves faster planning times, lower memory usage, and higher success rates than the traditional A∗ algorithm and several recent variants. These improvements enhance the algorithm's applicability to real-time autonomous navigation systems and contribute to the ongoing evolution of heuristic search techniques. The proposed enhancements strike a balance between computational efficiency and path quality, offering a scalable solution for intelligent path planning in dynamic environments. © 2025 IEEE.},
	type = {Conference paper},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 0}
}

