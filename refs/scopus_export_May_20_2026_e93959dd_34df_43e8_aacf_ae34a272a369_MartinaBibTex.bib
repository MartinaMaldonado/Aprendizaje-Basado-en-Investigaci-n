@CONFERENCE{Jung200497,
	author = {Jung, Dongmin and Kim, Hyungil and Kim, Juntae and Um, Kyhyun and Cho, Hyungje},
	title = {Efficient path finding in 3D games by using visibility tests with the A* algorithm},
	year = {2004},
	journal = {Proceedings of the Eighth IASTED International Conference on Artificial Intelligence and Soft Computing},
	pages = {97 - 101},
	url = {https://www.scopus.com/pages/publications/10444265199?origin=resultslist},
	abstract = {In this paper, we propose an efficient method of path finding in 3D games where the terrain is represented by navigation meshes. Our method uses the visibility tests with the A* algorithm. When the A* algorithm is applied to elaborated polygonal meshes for detailed terrain representation, the path finding can be very inefficient because there are too many states (polygons) to be searched. In our method, we reduce the search space by using visibility tests so that the search can be fast even on the detailed terrain with large number of polygons. First we find the visible vertices of the obstacles, and define the heuristic function of A* as the distance to the goal through those vertices. By doing that, the number of states that the A* search visits can be substantially reduced compared to the plane search with straight-line distance heuristic.},
	type = {Conference paper},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 2}
}

@CONFERENCE{Bate19881114,
	author = {Bate, Stephen and Stanley, Kevin},
	title = {HEURISTIC ROUTE PLANNING: AN APPLICATION TO FIGHTER AIRCRAFT.},
	year = {1988},
	journal = {IEEE Proceedings of the National Aerospace and Electronics Conference},
	pages = {1114 - 1120},
	url = {https://www.scopus.com/pages/publications/0023758029?origin=resultslist},
	abstract = {A route-planner system prototype is described that finds an optimal or near-optimal path for survivable low-level penetration through hostile enemy threats. The planner considers terrain and physical obstacles, threats, fuel constraints, time constraints, aircraft performance characteristics, and pilot input. The mission-level route planner generates a route that includes fuel and time requirements, distance, threat exposure, and metrics to indicate the quality of the path. This path is then passed to a tactical-level route planner that uses models of the ownship and threat capability to generate a detailed flyable route. The A* heuristic search algorithm was selected to determine the routes due to its flexibility and efficient use of computing resources. A route-planner development workstation is also described. This workstation is used to prototype heuristic evaluation functions for the A* algorithm.},
	type = {Conference paper},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 6}
}

@CONFERENCE{Abishek2025,
	author = {Abishek, G. and Gokul Vasan, P. and Janarthanan, N. and Kumar, P.},
	title = {Path planning using Hybrid Routing Algorithm},
	year = {2025},
	journal = {Proceedings - 3rd International Conference on Artificial Intelligence and Machine Learning Applications: Healthcare and Internet of Things, AIMLA 2025},
	pages = {},
	doi = {10.1109/AIMLA63829.2025.11040851},
	url = {https://www.scopus.com/pages/publications/105010564760?origin=resultslist},
	abstract = {The aim of this hybrid algorithm is to design and refine a path-finding technique that integrates A ∗ (A-star) and Dijkstra's algorithms, enhancing the efficiency of route planning by utilizing the advantages of both approaches. The method applies the advantages of the two algorithms by adapting them according to the density of the environment. Dijkstra's algorithm is an optimal search algorithm that tries all possible paths to find the shortest path, but is resource-intensive in complex or large environments. The A∗(A-star) algorithm optimizes performance by using heuristics to estimate the cost of reaching the goal, thus focusing on dependency and avoiding unnecessary computations. The hybrid strategy attempts to achieve performance and efficiency by combining A ∗ 's efficiency in sparse setting and Dijkstra's extensive search in dense setting. Thus, it maximizes optimal path-finding while minimizing computational effort. Large-scale simulations were performed in MATLAB to compare the algorithm's performance in different environments with varying challenges. The comparison involves the evaluation of the efficiency, effectiveness, and computational complexity of the hybrid algorithm with respect to the standalone A ∗ algorithm and Dijkstra's algorithm implementations.  © 2025 IEEE.},
	type = {Conference paper},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 0}
}

@CONFERENCE{Akshya2023,
	author = {Akshya, J. and Mehra, Vinit and Sundarrajan, M. and Sri, Pattapu Teja and Sathish, R.},
	title = {Optimizing Real-Time Path Planning for NPC Navigation: Leveraging CentA∗ Algorithm to Enhance Efficiency and Adaptability},
	year = {2023},
	journal = {2023 1st International Conference on Advances in Electrical, Electronics and Computational Intelligence, ICAEECI 2023},
	pages = {},
	doi = {10.1109/ICAEECI58247.2023.10370778},
	url = {https://www.scopus.com/pages/publications/85183560837?origin=resultslist},
	abstract = {Modern game development heavily relies on AI pathfinding to enable non-player characters (NPCs) to navigate the game world efficiently. The use of pathfinding algorithms is essential for creating a believable and immersive gaming experience. A popular choice among the various pathfinding algorithms used in game development is the A∗ algorithm, which combines heuristic and graph search techniques to find the optimal path for NPCs. In this paper, the CentA∗ algorithm is introduced as an extension of A∗ that enhances the selection of starting and ending nodes, triggering NPC behaviours before reaching their destination. The gaming model is built using Unreal Engine 5 Blueprints, which incorporates the pathfinding algorithm and detection of enemy behavior that can be reused for different creature types with various character models. The pathfinding algorithm ensures that NPCs move in a realistic and efficient manner, enhancing the overall gaming experience. The introduction of CentA∗ offers an improvement over the traditional A∗ algorithm. A comparison of the proposed algorithm is done over the other existing algorithms and a minimization of the overall tour length is encountered. Compared to other existing algorithms, the proposed algorithm offers superior performance by reducing the overall tour length by a minimum of 0.67%. Although the proposed algorithm may lead to a slight increase in tour length by approximately 1.42%, it remains time-efficient and computes fewer blocks than other algorithms. These results demonstrate the potential of the proposed algorithm for optimizing tours in various contexts such as route planning and logistics. This paper emphasizes the significance of pathfinding algorithms in game development, particularly in creating a realistic and immersive gaming experience for players. The implementation of CentA∗ has significantly enhanced the behavior of NPCs in games. © 2023 IEEE.},
	type = {Conference paper},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 1}
}

@ARTICLE{Yuan20251832,
	author = {Yuan, Yuan and Liu, Yanqing and Zhu, Dongchen and Li, Jiamao and Zhang, Xiaolin and Peng, Yu},
	title = {Canonical Ordering Tree Adaptive A},
	year = {2025},
	journal = {Chinese Journal of Electronics},
	volume = {34},
	number = {6},
	pages = {1832 - 1844},
	doi = {10.23919/cje.2024.00.024},
	url = {https://www.scopus.com/pages/publications/105026855705?origin=resultslist},
	abstract = {Agents, such as robots and video game characters, have to be able to navigate from a given starting location to a known goal location in initially unknown or partially known terrains. These agents are usually able to sense obstacles around them. Under the free-space assumption, the agent assumes that the entire terrain is traversable except the blocked areas. The agent's knowledge may change and the current plan will be invalid. Therefore, replanning is needed. A common approach is that the agent repeatedly searches and finds the cost-minimal path from its location to the goal location and follows the path until it reaches the goal location. These searches need to be fast otherwise the agent cannot move smoothly. Incremental heuristic search algorithms use previous and current searches to solve future similar search problems faster than heuristic search algorithms that solve the individual search problems in isolation such as repeated A*. We propose canonical ordering tree adaptive A* algorithm which is one of the incremental heuristic search algorithms in the context of goal-directed navigation in unknown terrain represented by grids. © 2015 Chinese Institute of Electronics.},
	type = {Article},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 0}
}

